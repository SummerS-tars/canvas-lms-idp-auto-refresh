# 必填：学号
ELEARNING_USERNAME=YOUR_STUDENT_ID

# 必填：密码
ELEARNING_PASSWORD=YOUR_PASSWORD

# 可选：SSO 入口（默认会自动跳到 id.fudan.edu.cn）
# ELEARNING_ENTRY_URL=https://elearning.fudan.edu.cn/login/cas

# 可选：IDP 相关配置（通常无需修改）
# ELEARNING_IDP_BASE_URL=https://id.fudan.edu.cn
# ELEARNING_ENTITY_ID=https://elearning.fudan.edu.cn

# 可选：Canvas token 接口
# ELEARNING_TOKEN_API_URL=https://elearning.fudan.edu.cn/api/v1/users/self/tokens
# ELEARNING_SETTINGS_REFERER=https://elearning.fudan.edu.cn/profile/settings

# 可选：Token purpose
ELEARNING_TOKEN_PURPOSE=OpenClaw Auto Refresh Token

# 可选：创建后自动清理旧 token（按 purpose 匹配）
# 1=true / 0=false
# ELEARNING_CLEANUP_OLD_TOKENS=0

# 可选：清理用 purpose（默认使用新建 token 的 purpose）
# ELEARNING_CLEANUP_PURPOSE=OpenClaw Auto Refresh Token

# 可选：请求超时（秒）
# ELEARNING_TIMEOUT_SECONDS=20
